    "db:reset": "bun src/db/seed.ts reset",
    "db:delete": "bun src/db/seed.ts delete"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1"
  }
}
